# Database — on Railway, use a persistent volume mounted at /data
DATABASE_URL="file:/data/db.sqlite"

# JWT — generate a strong secret: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_USE_A_STRONG_RANDOM_SECRET"
JWT_EXPIRATION="7d"

# Server port — Railway sets this automatically
PORT=3001

# Uploads directory — on Railway, store on the persistent volume
UPLOAD_DIR="/data/uploads"

# Frontend origin for CORS — set to your Railway frontend URL
FRONTEND_URL="https://your-frontend.up.railway.app"
