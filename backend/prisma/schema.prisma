generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  poste     String?
  role      String   @default("PARTICIPANT")
  createdAt DateTime @default(now())

  attendances     Attendance[]
  evaluations     Evaluation[]
  seminarsCreated Seminar[]    @relation("SeminarCreator")
}

model Seminar {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  location    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  creatorId String
  creator   User   @relation("SeminarCreator", fields: [creatorId], references: [id])

  attendances Attendance[]
  evaluations Evaluation[]
  resources   Resource[]
}

model Attendance {
  id            String   @id @default(uuid())
  signatureData String
  signedAt      DateTime @default(now())
  guestName     String?
  guestPoste    String?

  seminarId String
  seminar   Seminar @relation(fields: [seminarId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

model Evaluation {
  id          String   @id @default(uuid())
  submittedAt DateTime @default(now())

  nom   String?
  poste String?

  pertinence        String
  objectifsAtteints String
  niveauAdaptation  String
  themesCommentaire String?

  methodeEfficace         String
  maitriseSujet           String
  participationEncouragee String
  rythme                  String

  logistique                String
  supportsClairs            String
  ameliorationsOrganisation String?

  competencesAcquises String
  recommandation      Boolean
  satisfactionGlobale Int

  plusAppreciee   String?
  pointsAmeliorer String?

  seminarId String
  seminar   Seminar @relation(fields: [seminarId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

model Resource {
  id        String   @id @default(uuid())
  name      String
  type      String
  url       String
  size      Int?
  createdAt DateTime @default(now())

  seminarId String
  seminar   Seminar @relation(fields: [seminarId], references: [id], onDelete: Cascade)
}
